# ──────────────────────────────────────────────────────────
#  blog-system 多站点构建配置
#  复制为 .env（master）或 .env.production（子仓）
# ──────────────────────────────────────────────────────────

# 是否为面向用户的子仓（true = 子仓，false = master 控制台，默认 false）
# 子仓会：
#  - 剔除 /admin/* 路由（节省 bundle，攻击面更小）
#  - 隐藏"登录"按钮和管理后台入口
#  - footer 显示"由 blog-system 管理"
VITE_PUBLIC_ONLY=false

# 主仓地址（footer 链接 + 来源标识）
VITE_MASTER_URL=https://github.com/Omlandc/blog-system

# 是否在 footer 显示"由 blog-system 管理"（默认 true）
# 子仓一般显示；如果你想完全静默，可以设为 false
VITE_SHOW_POWERED_BY=true