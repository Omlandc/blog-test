{
  "name": "blog-system",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A production-grade blog & article creation system",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/post-build.mjs",
    "build:static": "node scripts/export-static.mjs --input=articles.json && npm run build",
    "export:static": "node scripts/export-static.mjs",
    "preview": "npm run build && wrangler dev",
    "typecheck": "tsc -b --noEmit",
    "postbuild": "node scripts/post-build.mjs",
    "migrate": "node scripts/migrate.mjs",
    "migrate:project": "node scripts/migrate.mjs --write-project",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.1.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "dompurify": "^3.1.7",
    "esbuild": "^0.28.1",
    "framer-motion": "^11.11.17",
    "highlight.js": "^11.10.0",
    "jsdom": "^29.1.1",
    "lucide-react": "^0.460.0",
    "marked": "^14.1.4",
    "minisearch": "^7.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.28.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.3",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "wrangler": "^4.105.0"
  }
}
